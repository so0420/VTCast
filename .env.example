# VTCast relay configuration
# Copy this file to `.env` next to the vtcast-relay binary (or run-from dir)
# and fill in the values. The relay loads .env on startup; values already
# exported in the shell / systemd take precedence.

# Bind address. Use 0.0.0.0 for public hosting, 127.0.0.1 for local only.
VTCAST_RELAY_BIND=0.0.0.0:17239

# TURN listener port (UDP). Open this in your firewall.
VTCAST_TURN_PORT=3478

# Server's real public IP. This is what TURN advertises to clients as the
# relay candidate — must be the routable IP, NOT 127.0.0.1 or the bind addr.
VTCAST_TURN_PUBLIC_IP=

# Hostname (or IP) clients see in the `turn:<here>:3478` URL. Using a domain
# here lets you change servers later without re-issuing clients.
VTCAST_TURN_ADVERTISED=vtcast.jamku.me

# 32-byte hex secret for TURN credential HMAC. MUST be stable across restarts
# — otherwise every relay restart invalidates all outstanding credentials.
# Generate once with:  openssl rand -hex 32
VTCAST_TURN_SECRET=

# Log filter (optional). Default: info,vtcast_relay=debug
# RUST_LOG=info
